{
  "name": "@adopture/react-native",
  "version": "0.1.0",
  "description": "Privacy-first mobile analytics SDK for React Native & Expo",
  "source": "src/index.ts",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "react-native": "src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "react-native": "./src/react/index.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "bunup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "analytics",
    "react-native",
    "expo",
    "privacy",
    "mobile",
    "tracking"
  ],
  "homepage": "https://adopture.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Adopture/adopture-react-native"
  },
  "bugs": {
    "url": "https://github.com/Adopture/adopture-react-native/issues"
  },
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.70.0",
    "@react-native-async-storage/async-storage": ">=1.19.0",
    "@react-native-community/netinfo": ">=9.0.0",
    "@react-navigation/native": ">=6.0.0",
    "expo-localization": ">=14.0.0",
    "expo-constants": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "@react-native-community/netinfo": {
      "optional": true
    },
    "@react-navigation/native": {
      "optional": true
    },
    "expo-localization": {
      "optional": true
    },
    "expo-constants": {
      "optional": true
    }
  },
  "dependencies": {
    "react-native-get-random-values": "^2.0.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/native": "^7.2.2",
    "@types/react": "^19.2.14",
    "bunup": "^0.16.0",
    "react": "^19.2.4",
    "react-native": "^0.85.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.3"
  }
}
